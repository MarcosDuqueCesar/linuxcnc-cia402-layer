component cia402_drive_stub "Simulated CiA402 drive stub for HAL testing (PDS + homing + opmode_display + fault injection)";

pin in  u32 in_controlword "Simulated 0x6040 controlword input";
pin in  s32 in_opmode      "Simulated 0x6060 opmode request (6=Homing, 8=CSP, etc)";
pin in  s32 in_target_position "Simulated 0x607A target position (counts)";

pin out u32 out_statusword "Simulated 0x6041 statusword (lower 16 bits used)";
pin out s32 out_opmode_display "Simulated 0x6061 opmode display";
pin out s32 out_actual_position "Simulated 0x6064 actual position (counts)";

/* Existing params (kept) */
param rw u32 opmode_apply_delay_cycles = 20;
param rw u32 homing_run_cycles = 50;
param rw u32 done_hold_cycles  = 30;

param rw u32 statusword_base = 0x0237;
param rw u32 homing_done_mask  = 0x1400;
param rw u32 homing_done_value = 0x1400;

/* New params: PDS simulation + faults */
param rw bit pds_sim_enable = FALSE;
param rw u32 pds_initial_state = 0;            /* 0=SOD, 1=RTSO, 2=SO, 3=OE */
param rw u32 pds_transition_delay_cycles = 20; /* delay per transition step */

param rw bit inject_fault = FALSE;             /* force FAULT state */
param rw u32 fault_reset_delay_cycles = 50;    /* delay after seeing 0x80 to clear fault */

function update;
license "GPL";

;;

#include <stdint.h>

#define SWMASK_STATE             0x006Fu
#define ST_SWITCH_ON_DISABLED    0x0040u
#define ST_READY_TO_SWITCH_ON    0x0021u
#define ST_SWITCHED_ON           0x0023u
#define ST_OPERATION_ENABLED     0x0027u
#define ST_FAULT                 0x0008u

#define SW_BIT_VOLTAGE_ENABLED   (1u<<4)
#define SW_BIT_QUICK_STOP        (1u<<5)
#define SW_BIT_REMOTE            (1u<<9)
#define SW_BIT_FAULT             (1u<<3)

#define CW_BIT_FAULT_RESET       (1u<<7)

enum {
    PDS_SOD = 0,
    PDS_RTSO = 1,
    PDS_SO = 2,
    PDS_OE = 3,
    PDS_FAULT = 4
};

static int32_t  opmode_shadow;
static uint32_t opmode_cnt;

static uint32_t homing_active;
static uint32_t homing_cnt;
static uint32_t done_cnt;
static uint32_t cw4_prev;

static uint32_t pds_state;
static uint32_t pds_cnt;
static uint32_t fr_cnt;
static uint32_t fr_armed;

static uint32_t make_statusword_from_pds(uint32_t pds)
{
    uint32_t sw = 0;

    /* Keep some bits stable/industrial-ish */
    sw |= SW_BIT_QUICK_STOP;
    sw |= SW_BIT_REMOTE;

    switch (pds) {
        case PDS_SOD:
            sw |= ST_SWITCH_ON_DISABLED;
            break;

        case PDS_RTSO:
            sw |= ST_READY_TO_SWITCH_ON;
            sw |= SW_BIT_VOLTAGE_ENABLED;
            break;

        case PDS_SO:
            sw |= ST_SWITCHED_ON;
            sw |= SW_BIT_VOLTAGE_ENABLED;
            break;

        case PDS_OE:
            sw |= ST_OPERATION_ENABLED;
            sw |= SW_BIT_VOLTAGE_ENABLED;
            break;

        case PDS_FAULT:
        default:
            sw |= ST_FAULT;
            sw |= SW_BIT_FAULT;
            break;
    }

    return sw;
}

FUNCTION(update)
{
    (void)period;

    /* Actual position follows target (simple model) */
    out_actual_position = in_target_position;

    /* Opmode display follows requested opmode after a delay */
    if (in_opmode != opmode_shadow) {
        opmode_shadow = in_opmode;
        opmode_cnt = 0;
    }
    if (opmode_cnt < opmode_apply_delay_cycles) {
        opmode_cnt++;
    } else {
        out_opmode_display = opmode_shadow;
    }

    /* One-time init */
    static int init_done = 0;
    if (!init_done) {
        if (!pds_sim_enable) {
            pds_state = PDS_OE; /* legacy mode assumes enabled-ish */
        } else {
            if (pds_initial_state > 3) pds_initial_state = 0;
            pds_state = pds_initial_state;
        }
        pds_cnt = 0;
        fr_cnt = 0;
        fr_armed = 0;
        init_done = 1;
    }

    /* Base statusword */
    uint32_t sw;
    if (!pds_sim_enable) {
        sw = (uint32_t)statusword_base;
    } else {
        /* Fault injection */
        if (inject_fault) {
            pds_state = PDS_FAULT;
        }

        /* Fault reset: see bit7 (0x80), then clear fault after delay */
        uint32_t fr = (in_controlword & CW_BIT_FAULT_RESET) ? 1u : 0u;
        if (pds_state == PDS_FAULT) {
            if (fr && !fr_armed) {
                fr_armed = 1;
                fr_cnt = 0;
            }
            if (fr_armed) {
                if (fr_cnt < fault_reset_delay_cycles) {
                    fr_cnt++;
                } else {
                    if (!inject_fault) {
                        pds_state = PDS_SOD;
                    }
                    fr_armed = 0;
                }
            }
        } else {
            fr_armed = 0;
        }

        /* PDS transitions based on cw lower nibble */
        if (pds_state != PDS_FAULT) {
            uint32_t cw = (uint32_t)in_controlword;

            if ((cw & 0x000Fu) == 0x0000u) {
                pds_state = PDS_SOD;
                pds_cnt = 0;
            } else {
                if (pds_cnt < pds_transition_delay_cycles) {
                    pds_cnt++;
                } else {
                    uint32_t cmd = (cw & 0x000Fu);
                    if (cmd == 0x0006u) {
                        pds_state = PDS_RTSO;
                    } else if (cmd == 0x0007u) {
                        if (pds_state == PDS_RTSO || pds_state == PDS_SOD) pds_state = PDS_SO;
                    } else if (cmd == 0x000Fu) {
                        if (pds_state == PDS_SO || pds_state == PDS_RTSO) pds_state = PDS_OE;
                    }
                    pds_cnt = 0;
                }
            }
        }

        sw = make_statusword_from_pds(pds_state);
    }

    /* Homing logic (kept) */
    uint32_t cw4 = (in_controlword >> 4) & 1u;
    uint32_t cw4_rise = (cw4 && !cw4_prev);
    cw4_prev = cw4;

    if (cw4_rise && (out_opmode_display == 6)) {
        homing_active = 1;
        homing_cnt = 0;
        done_cnt = 0;
    }

    if (homing_active) {
        if (homing_cnt < homing_run_cycles) {
            homing_cnt++;
        } else {
            sw = (sw & ~homing_done_mask) | (homing_done_value & homing_done_mask);
            if (done_cnt < done_hold_cycles) {
                done_cnt++;
            } else {
                homing_active = 0;
            }
        }
    }

    out_statusword = sw;
}
